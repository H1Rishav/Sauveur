# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MODEL_DOER: Default model for the Doer agent
MODEL_DOER="gemini-1.5-flash"
# MODEL_PLANNER: Default model for the Planner agent
MODEL_PLANNER="gemini-1.5-flash"
# MODEL_PROFILER: Default model for the Profiler agent
MODEL_PROFILER="gemini-1.5-flash"
# MODEL_STRATEGIST: Default model for the Strategist agent
MODEL_STRATEGIST="gemini-1.5-flash"

# CUSTOM_GEMINI_API_KEY: Optional user-supplied custom Gemini API key.
# If provided, this key will be used instead of the platform-managed GEMINI_API_KEY.
# Paste your explicit Gemini API key here in the Secrets settings.
CUSTOM_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SESSION_SECRET: Required for Express cryptographically signed session cookies.
SESSION_SECRET="ANY_RANDOM_LONG_SECRET_KEY"

# JWT_SECRET: Required for signing and verifying JSON Web Tokens for API authentication.
JWT_SECRET="ANY_RANDOM_LONG_SECRET_KEY"

# MAIL_USER: Gmail mailbox address for sending dispatches (e.g., example@gmail.com)
MAIL_USER=""

# MAIL_APP_PASSWORD: App password generated in Google Account settings (not standard password)
MAIL_APP_PASSWORD=""


